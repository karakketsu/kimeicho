---
layout: base.njk
title: 安普請 — NOVEL ARCHIVE
nav: home
permalink: /home/
---
<div class="section-label">CONTENTS — 小説（新着）</div>
<p class="section-index">全{{ collections.novels.length }}作品 — <a href="/novels/">すべて見る →</a></p>

<table class="works">
  {% for item in collections.novels | reverse | slice(0, 8) %}
  <tr>
    <td class="date">{{ item.data.date | ym }}</td>
    <td class="title">
      <a href="{{ item.url }}">{{ item.data.title }}</a>
      <span class="tags">
        {% if item.data.rating %}<span class="tag rating">{{ item.data.rating }}</span>{% endif %}
        {% for p in item.data.pairing %}<span class="tag">{{ p }}</span>{% endfor %}
      </span>
    </td>
    <td class="note">{{ item.data.type }}</td>
  </tr>
  {% endfor %}
</table>

<div class="section-label">BLOG</div>
<p class="section-index">不定期更新 — <a href="/blog/">すべて見る →</a></p>

{% for post in collections.posts | reverse | slice(0, 3) %}
<div class="post">
  <p class="post-meta">{{ post.data.date | ym }}</p>
  <p class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></p>
  <div class="post-body">{{ post.data.excerpt or "" }}</div>
</div>
{% endfor %}
