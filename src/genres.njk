<div class="section-label">GENRES</div>
<p class="section-index">ジャンル(原作)ごとの一覧</p>

<ul class="index-list">
  {% for entry in collections.fandomList %}
  <li class="{{ 'favorite' if entry.fandom == 'お気に入り' }}">
    <a href="/genres/{{ entry.fandom | slugify }}/">{% if entry.fandom == 'お気に入り' %}★ {% endif %}{{ entry.fandom }}</a>
    <span class="count">{{ entry.items.length }}作品</span>
  </li>
  {% endfor %}
  <li class="key-link"><a href="/vault/">🔒 鍵</a></li>
  <li class="key-link"><a href="/request/">🔒 鍵の申請はこちら</a></li>
</ul>
